# Host paths for Claude CLI bind mounts.
# Copy to .env and adjust for your setup before running docker-compose.
#
# CLAUDE_BIN   — absolute host path to the claude binary
# CLAUDE_HOME  — absolute host path to the claude auth/config directory (~/.claude)
#
# Default values (match a standard claude CLI install at /root/.claude):
#   CLAUDE_BIN=/root/.claude/npm-global/bin/claude
#   CLAUDE_HOME=/root/.claude
#
# Unraid example (if ClaudeClaw appdata is at /mnt/user/appdata/claudeclaw):
#   CLAUDE_BIN=/mnt/user/appdata/claudeclaw/.claude/npm-global/bin/claude
#   CLAUDE_HOME=/mnt/user/appdata/claudeclaw/.claude

CLAUDE_BIN=/root/.claude/npm-global/bin/claude
CLAUDE_HOME=/root/.claude
